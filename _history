ED: Explicitly telling the compiler that 'Stats' incoming must be treated as an array layout\n    //% block=\"Create Stats $Stats with name $name\"\n    export function addStats(Stats: any[], name: string): void {\n        ListOfStats.push([name, Stats])\n    }\n\n    //% block=\"get Stats from stat with name $name || at index $index\"\n    export function getStats(name: string, index?: number): any {\n        for (let i = 0; i < ListOfStats.length; i++) {\n            // FIX 1: Force MakeCode to see each row folder as an array layout\n            let folder = ListOfStats[i] as any[]\n\n            if (folder[0] == name) {\n                // FIX 2: Force MakeCode to see the stats pocket as a true sub-array layout\n                let currentStats = folder[1] as any[]\n\n                // If no index was dragged into the block, return the whole array box safely\n                if (index == undefined) {\n                    return currentStats\n                }\n\n                // FIX 3: Now the compiler safely processes these indexes without the t.findIdx crash!\n                if (index == 0) {\n                    return folder[0]       // Index 0: Returns Name string\n                } else if (index == 1) {\n                    return currentStats[0]   // Index 1: Returns Image asset safely\n                } else if (index == 2) {\n                    return currentStats[2]   // Index 2: Returns Level number safely\n                }\n            }\n        }\n        return false\n    }\n}","pxt.json":"{\n    \"name\": \"Untitled\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"device\": \"*\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\",\n        \"assets.json\",\n        \"StatsArray.ts\"\n    ],\n    \"preferredEditor\": \"blocksprj\"\n}\n"}},{"timestamp":1783782291324,"editorVersion":"4.0.14","text":{"main.blocks":"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables