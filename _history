f (ArrayParts[1] == name && ArrayParts[0] == list) {\n                StatsArray[i] = [\"\" + ArrayParts[0] + \"|\" + stats[0] + \"|\" + stats[1] + \"|\" + stats[2]]\n            }\n        }\n    }\n    //%block=\"get Random Stat from list with name $name || at index $index\"\n    //%group=\"Get\"\n    export function Get_random_stats(name: string, index?: number): any {\n        let matches: string[] = []\n        for (let i = 0; i < StatsArray.length; i++) {\n            ArrayItems = StatsArray[i]\n            useItems = ArrayItems[0]\n            ArrayParts = useItems.split(\"|\")\n            if (ArrayParts[0] == name) {\n                matches.push(useItems) \n            }\n        }\n        if (matches.length > 0) {\n            let randomIndex = randint(0, matches.length - 1)\n            if (index != undefined) {\n                let parts = matches[randomIndex].split(\"|\")\n                return parts[index] \n            } else {\n                return matches[randomIndex]\n            }\n        }\n        return undefined\n    }\n}","tilemap.g.jres":"{\n    \"transparency16\": {\n        \"data\": \"hwQQABAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA==\",\n        \"mimeType\": \"image/x-mkcd-f4\",\n        \"tilemapTile\": true\n    },\n    \"*\": {\n        \"mimeType\": \"image/x-mkcd-f4\",\n        \"dataEncoding\": \"base64\",\n        \"namespace\": \"myTiles\"\n    }\n}","tilemap.g.ts":"","pxt.json":"{\n    \"name\": \"Untitled\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"device\": \"*\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\",\n        \"assets.json\",\n        \"StatsArray.ts\",\n        \"tilemap.g.jres\",\n        \"tilemap.g.ts\"\n    ],\n    \"preferredEditor\": \"blocksprj\"\n}\n"}}],"shares":[],"lastSaveTime":1783788628574}